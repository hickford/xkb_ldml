<!DOCTYPE keyboard SYSTEM "../dtd/ldmlKeyboard.dtd">
<keyboard locale="zz-Brai-t-k0-linux">
  <version platform="0" number="$Revision$"/>
  <names>
    <name value="Braille"/>
    <name value="brai"/>
  </names>
  <settings transformFailure="omit" transformPartial="hide"/>
  <keyMap>
    <map iso="C12" to="\"/>
    <map iso="B00" to="&lt;"/>
    <map iso="A03" to=" "/>
  </keyMap>
  <keyMap modifiers="shift">
    <map iso="C12" to="|"/>
    <map iso="B00" to="&gt;"/>
    <map iso="A03" to=" "/>
  </keyMap>
  <keyMap modifiers="altR">
    <map iso="C12" to="\"/>
    <map iso="B00" to="&lt;"/>
    <map iso="A03" to=" "/>
  </keyMap>
  <keyMap modifiers="altR+shift">
    <map iso="C12" to="|"/>
    <map iso="B00" to="&gt;"/>
    <map iso="A03" to=" "/>
  </keyMap>
</keyboard>

